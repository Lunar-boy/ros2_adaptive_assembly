<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="adaptive_assembly_panda">
  <xacro:arg name="initial_positions_file" default=""/>
  <xacro:arg name="controllers_file" default=""/>
  <!--
    Compatibility argument retained for existing launch composition. The
    canonical MoveIt resources Panda collision geometry is always present.
  -->
  <xacro:arg name="enable_arm_collisions" default="true"/>

  <!--
    Canonical Panda links, joints, meshes, collision geometry, inertials, and
    limits. This lower-level description does not emit ros2_control systems.
  -->
  <xacro:include filename="$(find adaptive_assembly_sim)/urdf/panda.urdf.xacro"/>

  <link name="world"/>
  <joint name="panda_world_joint" type="fixed">
    <parent link="world"/>
    <child link="panda_link0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Anchor only the base in Gazebo; the canonical arm links remain dynamic. -->
  <gazebo reference="panda_link0">
    <kinematic>true</kinematic>
  </gazebo>

  <!-- Canonical finger collision names are preserved by URDF-to-SDF conversion. -->
  <gazebo reference="panda_leftfinger">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <sensor name="panda_leftfinger_contact_sensor" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>/panda_leftfinger_contact</topic>
      <contact>
        <collision>panda_leftfinger_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="panda_rightfinger">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <sensor name="panda_rightfinger_contact_sensor" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>/panda_rightfinger_contact</topic>
      <contact>
        <collision>panda_rightfinger_collision</collision>
      </contact>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="panda_joint1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-0.785</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint3">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint4">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-2.356</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint5">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint6">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">1.571</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint7">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.785</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_finger_joint1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.04</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_finger_joint2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.04</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_file)</parameters>
      <ros>
        <remapping>/robot_description:=/gazebo_panda/robot_description</remapping>
      </ros>
    </plugin>
  </gazebo>
</robot>
